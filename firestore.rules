rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── HELPER FUNCTIONS ─────────────────────────────────────────
    function isLoggedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }


    // ─── USERS COLLECTION ─────────────────────────────────────────
    // /users/{userId}
    match /users/{userId} {
      // Anyone logged in can read user profiles (for display)
      allow read: if isLoggedIn();

      // Only the owner can write/update their own profile
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;  // Prevent account deletion from frontend
    }


    // ─── BUYERS (REQUIREMENTS) COLLECTION ─────────────────────────
    // /buyers/{docId}
    match /buyers/{docId} {
      // Any logged-in user can read buyer requirements (farmers need to see them)
      allow read: if isLoggedIn();

      // Only logged-in users can create a requirement
      allow create: if isLoggedIn()
        && request.resource.data.buyerId == request.auth.uid
        && request.resource.data.qty is int
        && request.resource.data.price is int
        && request.resource.data.qty > 0
        && request.resource.data.price > 0;

      // Only the buyer who posted can update/delete their own requirement
      allow update: if isLoggedIn()
        && resource.data.buyerId == request.auth.uid;

      allow delete: if isLoggedIn()
        && resource.data.buyerId == request.auth.uid;
    }


    // ─── MESSAGES COLLECTION ──────────────────────────────────────
    // /messages/{msgId}
    match /messages/{msgId} {
      // Only sender or recipient can read a message
      allow read: if isLoggedIn()
        && (resource.data.senderId == request.auth.uid
         || resource.data.recipientId == request.auth.uid);

      // Any logged-in user can send a message
      allow create: if isLoggedIn()
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.content.size() > 0
        && request.resource.data.content.size() <= 1000;

      allow update: if false;  // Messages are immutable
      allow delete: if false;
    }


    // ─── RATINGS COLLECTION ───────────────────────────────────────
    // /ratings/{ratingId}
    match /ratings/{ratingId} {
      // Public - anyone logged in can read ratings
      allow read: if isLoggedIn();

      // Any logged-in user can leave a rating
      allow create: if isLoggedIn()
        && request.resource.data.ratedById == request.auth.uid
        && request.resource.data.stars >= 1
        && request.resource.data.stars <= 5;

      allow update, delete: if false;  // Ratings are permanent
    }

  }
}
